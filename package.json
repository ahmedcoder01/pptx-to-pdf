{
  "name": "pptx-to-pdf",
  "version": "0.1.0",
  "description": "Pure TypeScript PPTX-to-PDF converter — no LibreOffice, no native binaries",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "fonts"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate-fixtures": "tsx scripts/generate-fixtures.ts"
  },
  "keywords": [
    "pptx",
    "pdf",
    "powerpoint",
    "converter",
    "pptx-to-pdf",
    "pure-js",
    "no-libreoffice",
    "typescript",
    "presentation",
    "office"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=16"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AhmedEssam/pptx-to-pdf"
  },
  "dependencies": {
    "fast-xml-parser": "^4.5.0",
    "jszip": "^3.10.0",
    "opentype.js": "^1.3.4",
    "pdfkit": "^0.15.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pdfkit": "^0.13.0",
    "pptxgenjs": "^3.12.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
